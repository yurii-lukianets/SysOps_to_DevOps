      "id": 1,
      "title": "Uptime",
      "type": "stat",
      "gridPos": {"x": 0, "y": 0, "w": 4, "h": 3},
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "color": {"mode": "none"}
        }
      },
      "options": {
        "colorMode": "none",
        "graphMode": "none",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false},
        "textMode": "auto"
      },
      "targets": [{
        "expr": "node_time_seconds{job=\"aws-node-exporter\"} - node_boot_time_seconds{job=\"aws-node-exporter\"}",
        "legendFormat": "Uptime (s)",
        "instant": true
      }]
    },
    {
      "id": 2,
      "title": "Memory Total",
      "type": "stat",
      "gridPos": {"x": 4, "y": 0, "w": 4, "h": 3},
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "color": {"mode": "none"}
