{
  "__inputs": [],
  "__requires": [],
  "title": "AWS EC2 — System",
  "version": 1,
  "uid": "aws-ec2-system",
  "tags": ["aws", "ec2", "node-exporter"],
  "schemaVersion": 39,
  "timezone": "browser",
  "editable": true,
  "graphTooltip": 1,
  "panels": [
