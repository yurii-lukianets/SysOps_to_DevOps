    },
    {
      "id": 4,
      "title": "Swap Used",
      "type": "stat",
      "gridPos": {"x": 12, "y": 0, "w": 4, "h": 3},
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "rgba(74,222,128,0.85)", "value": null},
              {"color": "rgba(234,179,8,0.85)", "value": 1073741824},
              {"color": "rgba(248,113,113,0.85)", "value": 2147483648}
            ]
          },
          "color": {"mode": "thresholds"}
        }
      },
      "options": {
        "colorMode": "background",
        "graphMode": "sparkline",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false},
        "textMode": "auto"
      },
      "targets": [{
        "expr": "(node_memory_SwapTotal_bytes{job=\"aws-node-exporter\"} - node_memory_SwapFree_bytes{job=\"aws-node-exporter\"})",
        "legendFormat": "Swap used",
        "instant": true
      }]
    },
    {
      "id": 5,
      "title": "Memory Usage %",
      "type": "gauge",
      "gridPos": {"x": 16, "y": 0, "w": 4, "h": 3},
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "rgba(74,222,128,0.85)", "value": null},
              {"color": "rgba(234,179,8,0.85)", "value": 80},
              {"color": "rgba(248,113,113,0.85)", "value": 90}
            ]
          },
          "color": {"mode": "thresholds"}
        }
      },
      "options": {
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false},
        "showThresholdLabels": false,
        "showThresholdMarkers": true
      },
      "targets": [{
        "expr": "(1 - node_memory_MemAvailable_bytes{job=\"aws-node-exporter\"} / node_memory_MemTotal_bytes{job=\"aws-node-exporter\"}) * 100",
        "legendFormat": "Used %",
        "instant": true
      }]
