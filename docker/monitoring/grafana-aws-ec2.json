        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false},
        "textMode": "auto"
      },
      "targets": [{
        "expr": "node_memory_MemAvailable_bytes{job=\"aws-node-exporter\"}",
        "legendFormat": "Available",
        "instant": true
